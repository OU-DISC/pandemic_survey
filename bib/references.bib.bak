@article{biswas_covid-19_2020,
	title = {{COVID}-19 Data Visualization through Automatic Phase Detection},
	volume = {1},
	issn = {2691-199X, 2639-0175},
	url = {https://dl.acm.org/doi/10.1145/3411756},
	doi = {10.1145/3411756},
	abstract = {This article presents a new interactive visualization system to represent and compare rate of spread of {COVID}-19 pandemic across different countries over time. We surveyed existing visualization techniques used in various websites and media outlets and introduced use of a knee detection algorithm that divides the exponential spread in multiple linear components. A set of use cases demonstrates the utility of the system in comparing the spread across different countries for both analysis and prediction.},
	pages = {1--8},
	number = {4},
        journal = {Digit. Gov.: Res. Pract.},
